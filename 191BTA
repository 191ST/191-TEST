-- Function to get character tools
function getCharacterTools()
    local tools = {}
    if player.Character then
        for _, child in pairs(player.Character:GetChildren()) do
            if child:IsA("Tool") then
                table.insert(tools, child)
            end
        end
    end
    return tools
end

-- Function to find tool by name pattern
function findToolByName(pattern)
    local tools = getCharacterTools()
    for _, tool in pairs(tools) do
        if string.find(string.lower(tool.Name), string.lower(pattern)) then
            return tool
        end
    end
    return nil
end

-- Function to select and equip tool
function selectTool(toolName, buttonText)
    local tool = findToolByName(toolName)
    if tool and player.Character and player.Character:FindFirstChild("Humanoid") then
        -- Equip the tool
        player.Character.Humanoid:EquipTool(tool)
        return tool
    else
        return nil
    end
end

