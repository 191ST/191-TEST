-- MAIN LOOP FUNCTION (AUTO EQUIP + PRESS E + COOLDOWN)
function startMSLoop()
    if loopRunning then return end
    
    -- Validasi semua tool sudah dipilih
    if not waterTool or not sugarTool or not gelatinTool or not bagTool then
        MSLoopStepLabel.Text = "Error: Pilih semua tools dulu!"
        return
    end
    
    loopRunning = true
    MSLoopStatus.Text = "▶️ LOOP RUNNING"
    MSLoopStatus.TextColor3 = Color3.fromRGB(100,255,100)
    
    while loopRunning do
        -- STEP 1: WATER TOOL
        if not loopRunning then break end
        MSLoopStepLabel.Text = "Step 1: Equip WATER tool..."
        if equipTool(waterTool) then
            MSLoopStepLabel.Text = "Step 1: Pressing E - Cooldown 20s"
            pressE()
            waitWithTimer(20, "WATER")
        else
            MSLoopStepLabel.Text = "ERROR: Cannot equip WATER tool!"
            break
        end
        
        task.wait(0.3)
        if not loopRunning then break end
        
        -- STEP 2: SUGAR TOOL
        MSLoopStepLabel.Text = "Step 2: Equip SUGAR tool..."
        if equipTool(sugarTool) then
            MSLoopStepLabel.Text = "Step 2: Pressing E - Cooldown 2s"
            pressE()
            waitWithTimer(2, "SUGAR")
        else
            MSLoopStepLabel.Text = "ERROR: Cannot equip SUGAR tool!"
            break
        end
        
        task.wait(0.3)
        if not loopRunning then break end
        
        -- STEP 3: GELATIN TOOL
        MSLoopStepLabel.Text = "Step 3: Equip GELATIN tool..."
        if equipTool(gelatinTool) then
            MSLoopStepLabel.Text = "Step 3: Pressing E - Cooldown 45s"
            pressE()
            waitWithTimer(45, "GELATIN")
        else
            MSLoopStepLabel.Text = "ERROR: Cannot equip GELATIN tool!"
            break
        end
        
        task.wait(0.3)
        if not loopRunning then break end
        
        -- STEP 4: EMPTY BAG TOOL
        MSLoopStepLabel.Text = "Step 4: Equip BAG tool..."
        if equipTool(bagTool) then
            MSLoopStepLabel.Text = "Step 4: Pressing E - Cooldown 2s"
            pressE()
            waitWithTimer(2, "EMPTY BAG")
        else
            MSLoopStepLabel.Text = "ERROR: Cannot equip BAG tool!"
            break
        end
        
        task.wait(0.3)
        if not loopRunning then break end
        
        -- LOOP COMPLETE, RESTART
        MSLoopStepLabel.Text = "Loop complete! Restarting from WATER..."
        task.wait(1)
    end
    
    -- Cleanup
    loopRunning = false
    MSLoopStatus.Text = "⏹️ LOOP STOPPED"
    MSLoopStatus.TextColor3 = Color3.fromRGB(255,100,100)
    MSLoopStepLabel.Text = "Current Step: Stopped"
    MSLoopTimer.Text = "Timer: 0s"
end

-- Auto Buy Function
function startAutoBuy()
    if autoBuyRunning then return end
    autoBuyRunning = true
    currentBuyCount = 0
    AutoBuyStatus.Text = "💰 AUTO BUY RUNNING"
    AutoBuyStatus.TextColor3 = Color3.fromRGB(100,255,100)
    
    while autoBuyRunning and currentBuyCount < targetAmount do
        AutoBuyProgress.Text = string.format("Progress: %d/%d - Buying...", currentBuyCount + 1, targetAmount)
        pressE()
        task.wait(0.3)
        
        currentBuyCount = currentBuyCount + 1
        AutoBuyProgress.Text = string.format("Progress: %d/%d - Completed", currentBuyCount, targetAmount)
        SliderFill.Size = UDim2.new(currentBuyCount / targetAmount, 0, 1, 0)
        
        task.wait(0.5)
    end
    
    autoBuyRunning = false
    AutoBuyStatus.Text = "⏹️ AUTO BUY STOPPED"
    AutoBuyStatus.TextColor3 = Color3.fromRGB(255,100,100)
    if currentBuyCount >= targetAmount then
        AutoBuyProgress.Text = string.format("Progress: %d/%d - COMPLETE!", currentBuyCount, targetAmount)
    end
end

