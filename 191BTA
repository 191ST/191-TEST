-- Function to find tool by name
function findTool(namePattern)
    if not player.Character then return nil end
    
    -- Cek di tangan dulu
    local character = player.Character
    for _, child in pairs(character:GetChildren()) do
        if child:IsA("Tool") and string.find(string.lower(child.Name), string.lower(namePattern)) then
            return child
        end
    end
    
    -- Cek di backpack
    local backpack = player:FindFirstChild("Backpack")
    if backpack then
        for _, child in pairs(backpack:GetChildren()) do
            if child:IsA("Tool") and string.find(string.lower(child.Name), string.lower(namePattern)) then
                return child
            end
        end
    end
    
    return nil
end

-- Function to equip tool
function equipTool(tool)
    if not tool then return false end
    if not player.Character then return false end
    
    -- Kalo tool sudah di tangan
    if tool.Parent == player.Character then
        return true
    end
    
    -- Kalo tool di backpack
    if tool.Parent == player:FindFirstChild("Backpack") then
        -- Coba equip pake humanoid
        local humanoid = player.Character:FindFirstChild("Humanoid")
        if humanoid then
            humanoid:EquipTool(tool)
            task.wait(0.3)
            return tool.Parent == player.Character
        end
    end
    
    return false
end

-- Function to press E
function pressE()
    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
    task.wait(0.1)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
end

-- Function to wait with timer
function waitWithTimer(seconds, stepName)
    local startTime = tick()
    while loopRunning and (tick() - startTime) < seconds do
        local remaining = seconds - (tick() - startTime)
        MSLoopTimer.Text = string.format("Timer: %d/%ds - %s", math.floor(seconds - remaining), seconds, stepName)
        task.wait(0.1)
    end
    MSLoopTimer.Text = string.format("Timer: %d/%ds - %s Complete!", seconds, seconds, stepName)
end

