-- FIXED: Better key press function with tool activation
function pressKey(keyCode)
    VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
    task.wait(0.1)
    VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
end

-- FIXED: Hold key function with tool activation simulation
function holdKeyWithTool(keyCode, duration, toolName, toolIndex)
    -- First press to activate tool
    VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
    task.wait(0.2)
    
    -- Update tool indicator
    if toolIndex == 1 then
        MSLoopTool1.Text = "🟢 " .. toolName
        MSLoopTool1.TextColor3 = Color3.fromRGB(100,255,100)
    elseif toolIndex == 2 then
        MSLoopTool2.Text = "🟢 " .. toolName
        MSLoopTool2.TextColor3 = Color3.fromRGB(100,255,100)
    elseif toolIndex == 3 then
        MSLoopTool3.Text = "🟢 " .. toolName
        MSLoopTool3.TextColor3 = Color3.fromRGB(100,255,100)
    elseif toolIndex == 4 then
        MSLoopTool4.Text = "🟢 " .. toolName
        MSLoopTool4.TextColor3 = Color3.fromRGB(100,255,100)
    end
    
    -- Update timer during hold
    local startTime = tick()
    while loopRunning and (tick() - startTime) < duration do
        local elapsed = math.floor(tick() - startTime)
        local remaining = duration - elapsed
        MSLoopTimer.Text = string.format("Timer: %ds remaining", remaining)
        
        -- Keep sending key events to maintain tool activation
        if (tick() - startTime) % 1 < 0.1 then  -- Every second
            VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
        end
        
        task.wait(0.1)
    end
    
    -- Release key
    VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
    
    -- Reset tool indicator
    if toolIndex == 1 then
        MSLoopTool1.Text = "🔴 " .. toolName
        MSLoopTool1.TextColor3 = Color3.fromRGB(200,200,200)
    elseif toolIndex == 2 then
        MSLoopTool2.Text = "🔴 " .. toolName
        MSLoopTool2.TextColor3 = Color3.fromRGB(200,200,200)
    elseif toolIndex == 3 then
        MSLoopTool3.Text = "🔴 " .. toolName
        MSLoopTool3.TextColor3 = Color3.fromRGB(200,200,200)
    elseif toolIndex == 4 then
        MSLoopTool4.Text = "🔴 " .. toolName
        MSLoopTool4.TextColor3 = Color3.fromRGB(200,200,200)
    end
end

-- FIXED: Function to equip tool by number (1-4)
function equipTool(toolNumber)
    -- Press corresponding number key to equip tool
    local keyMap = {
        [1] = Enum.KeyCode.One,
        [2] = Enum.KeyCode.Two,
        [3] = Enum.KeyCode.Three,
        [4] = Enum.KeyCode.Four
    }
    
    if keyMap[toolNumber] then
        VirtualInputManager:SendKeyEvent(true, keyMap[toolNumber], false, game)
        task.wait(0.1)
        VirtualInputManager:SendKeyEvent(false, keyMap[toolNumber], false, game)
        task.wait(0.2) -- Wait for tool to equip
    end
end

-- FIXED: MS Loop Function with proper tool handling
function startMSLoop()
    if loopRunning then return end
    loopRunning = true
    MSLoopStatus.Text = "▶️ LOOP RUNNING"
    MSLoopStatus.TextColor3 = Color3.fromRGB(100,255,100)
    
    -- Reset all tool indicators
    MSLoopTool1.Text = "🔴 Water Tool"
    MSLoopTool2.Text = "🔴 Sugar Tool"
    MSLoopTool3.Text = "🔴 Gelatin Tool"
    MSLoopTool4.Text = "🔴 Empty Bag Tool"
    
    while loopRunning do
        -- Step 1: Equip and use Water tool (Slot 1) - 20 seconds
        MSLoopStepLabel.Text = "Current Step: WATER - Equipping tool 1"
        equipTool(1)
        task.wait(0.3)
        MSLoopStepLabel.Text = "Current Step: WATER (Hold E) - 20 seconds"
        holdKeyWithTool(Enum.KeyCode.E, 20, "Water Tool", 1)
        if not loopRunning then break end
        
        -- Brief pause between steps
        task.wait(0.5)
        
        -- Step 2: Equip and use Sugar Block Bag tool (Slot 2) - 1 second
        MSLoopStepLabel.Text = "Current Step: SUGAR - Equipping tool 2"
        equipTool(2)
        task.wait(0.3)
        MSLoopStepLabel.Text = "Current Step: SUGAR BLOCK BAG (Hold E) - 1 second"
        holdKeyWithTool(Enum.KeyCode.E, 1, "Sugar Tool", 2)
        if not loopRunning then break end
        
        task.wait(0.5)
        
        -- Step 3: Equip and use Gelatin tool (Slot 3) - 45 seconds
        MSLoopStepLabel.Text = "Current Step: GELATIN - Equipping tool 3"
        equipTool(3)
        task.wait(0.3)
        MSLoopStepLabel.Text = "Current Step: GELATIN (Hold E) - 45 seconds"
        holdKeyWithTool(Enum.KeyCode.E, 45, "Gelatin Tool", 3)
        if not loopRunning then break end
        
        task.wait(0.5)
        
        -- Step 4: Equip and use Empty Bag tool (Slot 4) - 1 second
        MSLoopStepLabel.Text = "Current Step: EMPTY BAG - Equipping tool 4"
        equipTool(4)
        task.wait(0.3)
        MSLoopStepLabel.Text = "Current Step: EMPTY BAG (Hold E) - 1 second"
        holdKeyWithTool(Enum.KeyCode.E, 1, "Empty Bag Tool", 4)
        if not loopRunning then break end
        
        task.wait(0.5)
        
        -- Loop complete, restart from beginning
        MSLoopStepLabel.Text = "Current Step: LOOP COMPLETE - Restarting from WATER"
        task.wait(1)
    end
    
    MSLoopStatus.Text = "⏹️ LOOP STOPPED"
    MSLoopStatus.TextColor3 = Color3.fromRGB(255,100,100)
    MSLoopStepLabel.Text = "Current Step: Stopped"
    MSLoopTimer.Text = "Timer: 0s"
    
    -- Reset all tool indicators
    MSLoopTool1.Text = "🔴 Water Tool"
    MSLoopTool2.Text = "🔴 Sugar Tool"
    MSLoopTool3.Text = "🔴 Gelatin Tool"
    MSLoopTool4.Text = "🔴 Empty Bag Tool"
end
