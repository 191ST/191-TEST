-- Key press function
function pressKey(keyCode)
    VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
    task.wait(0.1)
    VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
end

-- Function to equip specific tool
function equipTool(tool)
    if tool and tool.Parent ~= player.Character then
        -- Tool is in backpack, equip it
        local args = {
            [1] = tool
        }
        game:GetService("ReplicatedStorage").Remotes.Equip:InvokeServer(unpack(args))
        task.wait(0.3)
    end
    return tool and tool.Parent == player.Character
end

-- Function to use equipped tool (hold E)
function useTool(duration, stepName)
    if not loopRunning then return false end
    
    MSLoopStepLabel.Text = "Current Step: " .. stepName .. " (Using Tool)"
    
    -- Press and hold E
    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
    
    -- Update timer during hold
    local startTime = tick()
    while loopRunning and (tick() - startTime) < duration do
        local elapsed = math.floor(tick() - startTime)
        local remaining = duration - elapsed
        MSLoopTimer.Text = string.format("Timer: %ds remaining - %s", remaining, stepName)
        task.wait(0.1)
    end
    
    -- Release E
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
    
    return loopRunning
end

-- FIXED: MS Loop Function with proper tool handling
function startMSLoop()
    if loopRunning then return end
    
    -- Check if tools are selected
    if not selectedWaterTool or not selectedSugarTool or not selectedGelatinTool or not selectedBagTool then
        MSLoopStepLabel.Text = "Error: Please select all tools first!"
        return
    end
    
    loopRunning = true
    MSLoopStatus.Text = "▶️ LOOP RUNNING"
    MSLoopStatus.TextColor3 = Color3.fromRGB(100,255,100)
    
    while loopRunning do
        -- Step 1: WATER - 20 seconds
        if not loopRunning then break end
        if equipTool(selectedWaterTool) then
            MSToolStatus.Text = "Using: Water Tool"
            if not useTool(20, "WATER") then break end
        else
            MSLoopStepLabel.Text = "Error: Cannot equip Water tool!"
            break
        end
        
        task.wait(0.3)
        if not loopRunning then break end
        
        -- Step 2: SUGAR - 1 second
        if not loopRunning then break end
        if equipTool(selectedSugarTool) then
            MSToolStatus.Text = "Using: Sugar Tool"
            if not useTool(1, "SUGAR") then break end
        else
            MSLoopStepLabel.Text = "Error: Cannot equip Sugar tool!"
            break
        end
        
        task.wait(0.3)
        if not loopRunning then break end
        
        -- Step 3: GELATIN - 45 seconds
        if not loopRunning then break end
        if equipTool(selectedGelatinTool) then
            MSToolStatus.Text = "Using: Gelatin Tool"
            if not useTool(45, "GELATIN") then break end
        else
            MSLoopStepLabel.Text = "Error: Cannot equip Gelatin tool!"
            break
        end
        
        task.wait(0.3)
        if not loopRunning then break end
        
        -- Step 4: BAG - 1 second
        if not loopRunning then break end
        if equipTool(selectedBagTool) then
            MSToolStatus.Text = "Using: Bag Tool"
            if not useTool(1, "EMPTY BAG") then break end
        else
            MSLoopStepLabel.Text = "Error: Cannot equip Bag tool!"
            break
        end
        
        task.wait(0.3)
        if not loopRunning then break end
        
        -- Loop complete
        MSLoopStepLabel.Text = "Current Step: LOOP COMPLETE - Restarting"
        task.wait(1)
    end
    
    -- Cleanup
    loopRunning = false
    MSLoopStatus.Text = "⏹️ LOOP STOPPED"
    MSLoopStatus.TextColor3 = Color3.fromRGB(255,100,100)
    MSLoopStepLabel.Text = "Current Step: Stopped"
    MSLoopTimer.Text = "Timer: 0s"
    MSToolStatus.Text = "Tool: None"
end

-- Auto Buy Function
function startAutoBuy()
    if autoBuyRunning then return end
    autoBuyRunning = true
    currentBuyCount = 0
    AutoBuyStatus.Text = "💰 AUTO BUY RUNNING"
    AutoBuyStatus.TextColor3 = Color3.fromRGB(100,255,100)
    
    while autoBuyRunning and currentBuyCount < targetAmount do
        -- Buy Water
        AutoBuyProgress.Text = string.format("Progress: %d/%d - Buying Water...", currentBuyCount, targetAmount)
        pressKey(Enum.KeyCode.E)
        task.wait(0.2)
        
        -- Buy Sugar Block Bag
        AutoBuyProgress.Text = string.format("Progress: %d/%d - Buying Sugar...", currentBuyCount, targetAmount)
        pressKey(Enum.KeyCode.E)
        task.wait(0.2)
        
        -- Buy Gelatin
        AutoBuyProgress.Text = string.format("Progress: %d/%d - Buying Gelatin...", currentBuyCount, targetAmount)
        pressKey(Enum.KeyCode.E)
        task.wait(0.2)
        
        currentBuyCount = currentBuyCount + 1
        AutoBuyProgress.Text = string.format("Progress: %d/%d - Completed", currentBuyCount, targetAmount)
        SliderFill.Size = UDim2.new(currentBuyCount / targetAmount, 0, 1, 0)
        
        task.wait(0.5)
    end
    
    autoBuyRunning = false
    AutoBuyStatus.Text = "⏹️ AUTO BUY STOPPED"
    AutoBuyStatus.TextColor3 = Color3.fromRGB(255,100,100)
    if currentBuyCount >= targetAmount then
        AutoBuyProgress.Text = string.format("Progress: %d/%d - COMPLETE!", currentBuyCount, targetAmount)
    end
end

