UIS.InputChanged:Connect(function(i)
    if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
        local mouse = UIS:GetMouseLocation()
        local pos = SliderBg.AbsolutePosition
        local size = SliderBg.AbsoluteSize
        local x = math.clamp(mouse.X - pos.X, 0, size.X)
        local p = x / size.X
        targetAmount = math.floor(p * 99) + 1
        SliderFill.Size = UDim2.new(p, 0, 1, 0)
        SliderButton.Position = UDim2.new(p, -10, 0.5, -10)
        SliderValue.Text = "Target: " .. targetAmount
    end
end)

