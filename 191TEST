-- Main Loop
function startMSLoop()
    if loopRunning then return end
    if not waterTool or not sugarTool or not gelatinTool or not bagTool then
        MSLoopStepLabel.Text = "Pilih semua tools dulu!"
        return
    end
    
    loopRunning = true
    MSLoopStatus.Text = "▶️ RUNNING"
    MSLoopStatus.TextColor3 = Color3.fromRGB(100,255,100)
    
    while loopRunning do
        -- Water
        MSLoopStepLabel.Text = "Step 1: WATER - 20s"
        if equipTool(waterTool) then
            pressE()
            waitWithTimer(20, "WATER")
        else break end
        task.wait(0.2)
        
        -- Sugar
        MSLoopStepLabel.Text = "Step 2: SUGAR - 2s"
        if equipTool(sugarTool) then
            pressE()
            waitWithTimer(2, "SUGAR")
        else break end
        task.wait(0.2)
        
        -- Gelatin
        MSLoopStepLabel.Text = "Step 3: GELATIN - 45s"
        if equipTool(gelatinTool) then
            pressE()
            waitWithTimer(45, "GELATIN")
        else break end
        task.wait(0.2)
        
        -- Bag
        MSLoopStepLabel.Text = "Step 4: BAG - 2s"
        if equipTool(bagTool) then
            pressE()
            waitWithTimer(2, "BAG")
        else break end
        task.wait(0.2)
        
        MSLoopStepLabel.Text = "Loop complete! Restarting..."
        task.wait(1)
    end
    
    loopRunning = false
    MSLoopStatus.Text = "⏹️ STOPPED"
    MSLoopStatus.TextColor3 = Color3.fromRGB(255,100,100)
    MSLoopStepLabel.Text = "Stopped"
    MSLoopTimer.Text = "Timer: 0s"
end

-- Auto Buy
function startAutoBuy()
    if autoBuyRunning then return end
    autoBuyRunning = true
    currentBuyCount = 0
    AutoBuyStatus.Text = "💰 RUNNING"
    AutoBuyStatus.TextColor3 = Color3.fromRGB(100,255,100)
    
    while autoBuyRunning and currentBuyCount < targetAmount do
        AutoBuyProgress.Text = string.format("Progress: %d/%d", currentBuyCount + 1, targetAmount)
        pressE()
        currentBuyCount = currentBuyCount + 1
        SliderFill.Size = UDim2.new(currentBuyCount / targetAmount, 0, 1, 0)
        task.wait(0.3)
    end
    
    autoBuyRunning = false
    AutoBuyStatus.Text = "⏹️ STOPPED"
    AutoBuyStatus.TextColor3 = Color3.fromRGB(255,100,100)
    AutoBuyProgress.Text = string.format("Progress: %d/%d", currentBuyCount, targetAmount)
end

